# --- Server ---
NODE_ENV=development
PORT=8080
API_VERSION=v1
LOG_LEVEL=info

# --- Database ---
# DO App Platform provides MONGODB_URI via Managed Mongo binding.
# MONGO_URI is the legacy name and is still accepted.
MONGODB_URI=mongodb://localhost:27017/pilgrim-protect

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=30d

# --- CORS ---
# Comma-separated list of allowed origins. Falls back to CLIENT_URL if empty.
ALLOWED_ORIGINS=http://localhost:3000
CLIENT_URL=http://localhost:3000

# --- Cloudinary (optional — mock mode if unset) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Stripe (optional — mock mode if unset) ---
STRIPE_SECRET_KEY=sk_test_xxx

# --- Email (Brevo) ---
BREVO_API_KEY=

# --- Mapbox (backend-side use, if any) ---
MAPBOX_TOKEN=

# --- Observability ---
# Leave SENTRY_DSN empty to disable Sentry entirely.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_VERSION=
