# Copy to .env.local — Next.js loads this automatically in development.
# See ../LOCAL-DEV.md for the full local stack.

NODE_ENV=development

# Must match api PORT + /api/v1 (see api/.env.example)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_API_VERSION=v1

# false = browser calls the real Express API (needs Mongo + seeded data)
# true = use built-in mock data (no API required; good for UI-only work)
NEXT_PUBLIC_MOCK=false

# Required for /map — get a free token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional — custom Mapbox Studio style (defaults to mapbox light-v11)
# NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/yourusername/yourstyleid

# NextAuth (optional for donor pages that use auth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Main Pilgrim giving page (linked from /donate — v1 has no Stripe on this app)
NEXT_PUBLIC_EXTERNAL_GIVING_URL=https://pilgrimafrica.org

# Sentry — leave empty to disable
NEXT_PUBLIC_SENTRY_DSN=
